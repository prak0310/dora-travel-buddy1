        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  model: \"reka-flash\",\n  messages: [\n    {\n      role: \"user\",\n      content:\n        \"You are Dora, a travel activity expert. \" +\n        \"Given this Google Places result for a tourist activity or attraction, provide a detailed assessment. \" +\n        \"Use googleMapsUri as the url. If googleMapsUri is unavailable, use websiteUri. \" +\n        \"Return ONLY valid JSON with this exact format: \" +\n        \"{\\\"placeName\\\":\\\"\\\",\\\"verdict\\\":\\\"Highly Recommended / Worth Trying / Mixed / Overhyped\\\",\\\"confidence\\\":0,\\\"reason\\\":\\\"\\\",\\\"rating\\\":0,\\\"reviewCount\\\":0,\\\"url\\\":\\\"\\\",\\\"priceRange\\\":\\\"Free / Budget / Mid-range / Expensive\\\",\\\"duration\\\":\\\"e.g. 1-2 hours\\\",\\\"bestTime\\\":\\\"e.g. Morning / Evening / Anytime\\\",\\\"category\\\":\\\"e.g. Nature / Cultural / Adventure / Food / Nightlife\\\",\\\"goodFor\\\":[],\\\"ageSuitability\\\":\\\"All ages / Family friendly / Adults only / 18+\\\",\\\"locationArea\\\":\\\"\\\",\\\"indoorOutdoor\\\":\\\"Indoor / Outdoor / Both\\\",\\\"bookingRequired\\\":false,\\\"accessibility\\\":\\\"Easy / Moderate / Difficult\\\",\\\"watchOut\\\":[]} \" +\n        \"Google Places data: \" +\n        JSON.stringify($json)\n    }\n  ]\n}) }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        752,
        160
      ],
      "id": "60bf67ef-fb57-4502-970d-712398bdaa41",
      "name": "reka fact check"
    },
    {
      "parameters": {
        "jsCode": "return $input.all()\n  .map(item => {\n    if (item.json.error) return null;\n\n    const response = item.json.responses?.[0]?.message?.content;\n    if (!response) return null;\n\n    const cleaned = response\n      .replace(/```json/g, \"\")\n      .replace(/```/g, \"\")\n      .trim();\n\n    let parsed;\n    try {\n      parsed = JSON.parse(cleaned);\n    } catch (error) {\n      const match = cleaned.match(/\\{[\\s\\S]*\\}/);\n      if (match) {\n        try {\n          parsed = JSON.parse(match[0]);\n        } catch {\n          return null;\n        }\n      } else {\n        return null;\n      }\n    }\n\n    if (!parsed.placeName || parsed.placeName === \"Unknown\") return null;\n    if (!parsed.verdict) return null;\n\n    return { json: parsed };\n  })\n  .filter(item => item !== null);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        960,
        160
      ],
      "id": "30c2b5b7-4519-4da3-8e01-469343988f76",
      "name": "clean reka output"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const data = item.json;\n\n  return {\n    json: {\n      title: `🎯 ${data.placeName}`,\n      verdict: data.verdict,\n      confidence: data.confidence,\n      rating: data.rating,\n      reviewCount: data.reviewCount,\n      summary: data.reason,\n      url: data.url || null,\n      priceRange: data.priceRange || null,\n      duration: data.duration || null,\n      bestTime: data.bestTime || null,\n      category: data.category || null,\n      goodFor: data.goodFor || [],\n      ageSuitability: data.ageSuitability || null,\n      locationArea: data.locationArea || null,\n      indoorOutdoor: data.indoorOutdoor || null,\n      bookingRequired: data.bookingRequired || false,\n      accessibility: data.accessibility || null,\n      watchOut: data.watchOut || []\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
